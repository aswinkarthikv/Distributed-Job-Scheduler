datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Organization {
  id        String    @id @default(uuid())
  name      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  users     User[]
  projects  Project[]
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  passwordHash   String
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Project {
  id             String       @id @default(uuid())
  name           String
  description    String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  queues         Queue[]
  jobs           Job[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, name])
}

model Queue {
  id            String       @id @default(uuid())
  name          String
  concurrency   Int          @default(5)
  priority      String       @default("normal") // low, normal, high, critical
  paused        Boolean      @default(false)
  projectId     String
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  retryPolicyId String?      @unique
  retryPolicy   RetryPolicy? @relation(fields: [retryPolicyId], references: [id], onDelete: SetNull)
  jobs          Job[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([projectId, name])
}

model RetryPolicy {
  id            String   @id @default(uuid())
  attempts      Int      @default(3)
  backoffFactor Int      @default(2)
  delay         Int      @default(1000) // milliseconds
  queue         Queue?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Job {
  id              String          @id @default(uuid())
  name            String
  type            String          @default("immediate") // immediate, delayed, scheduled, recurring, batch
  status          String          @default("queued") // queued, scheduled, claimed, running, completed, failed, retrying, dead_letter, cancelled
  payload         String          @default("{}") // JSON string
  result          String?         // JSON string
  error           String?
  attempts        Int             @default(0)
  maxAttempts     Int             @default(3)
  priority        Int             @default(0)
  delay           Int             @default(0) // milliseconds
  cron            String?         // Cron expression
  batchId         String?
  queueId         String
  queue           Queue           @relation(fields: [queueId], references: [id], onDelete: Cascade)
  projectId       String
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workerId        String?
  worker          Worker?         @relation(fields: [workerId], references: [id], onDelete: SetNull)
  runAt           DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  failedAt        DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  executions      JobExecution[]
  logs            JobLog[]
  scheduledJobs   ScheduledJob[]
  deadLetterJobs  DeadLetterJob[]

  @@index([status])
  @@index([queueId])
  @@index([projectId])
}

model JobExecution {
  id         String    @id @default(uuid())
  jobId      String
  job        Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  workerId   String?
  worker     Worker?   @relation(fields: [workerId], references: [id], onDelete: SetNull)
  attempt    Int
  status     String
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  duration   Int?      // duration in milliseconds
  error      String?
  createdAt  DateTime  @default(now())

  @@index([jobId])
}

model ScheduledJob {
  id        String   @id @default(uuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  runAt     DateTime
  processed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([jobId])
}

model DeadLetterJob {
  id        String   @id @default(uuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  error     String?
  movedAt   DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([jobId])
}

model Worker {
  id            String            @id @default(uuid())
  name          String            @unique
  status        String            @default("offline") // online, busy, offline
  cpuUsage      Float             @default(0.0)
  memoryUsage   Float             @default(0.0)
  lastHeartbeat DateTime          @default(now())
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  jobs          Job[]
  executions    JobExecution[]
  heartbeats    WorkerHeartbeat[]
}

model WorkerHeartbeat {
  id          String   @id @default(uuid())
  workerId    String
  worker      Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  cpuUsage    Float
  memoryUsage Float
  timestamp   DateTime @default(now())

  @@index([workerId])
}

model JobLog {
  id        String   @id @default(uuid())
  jobId     String
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  message   String
  level     String   @default("info") // info, warn, error
  timestamp DateTime @default(now())

  @@index([jobId])
}
